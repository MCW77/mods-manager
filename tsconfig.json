{
	"compilerOptions": {
		"lib": ["DOM", "ESNext"],
		"allowJs": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"rootDir": "./src",
		"paths": {
			"#/*": ["./src/*", "./dist/*", "./"],
			"#lib/*": ["./src/lib/*"],
			"#ui/*": ["./src/components/ui/*"]
		},
		"types": ["@legendapp/state/types/babel", "node"],
		"noFallthroughCasesInSwitch": true,
		"noErrorTruncation": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules/**/*", "dist/**/*"],
	"typeAcquisition": {
		"enable": false
	}
}
