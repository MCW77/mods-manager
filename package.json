{
	"name": "mods-manager",
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"dev": "vite --host=127.0.0.1",
		"dev:scan": "set \"VITE_ENABLE_REACT_SCAN=true\"&& vite --host=127.0.0.1",
		"build": "tsgo && vite build",
		"forcedbuild": "vite build",
		"serve": "vite preview",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:migrations": "vitest run src/tests/migrations",
		"test:migrations:ui": "vitest --ui src/tests/migrations"
	},
