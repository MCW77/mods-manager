{
	"name": "mods-manager",
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"dev": "vite --host=127.0.0.1",
		"dev:scan": "set \"VITE_ENABLE_REACT_SCAN=true\"&& vite --host=127.0.0.1",
		"build": "tsgo && vite build",
		"forcedbuild": "vite build",
		"serve": "vite preview",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:migrations": "vitest run src/tests/migrations",
		"test:migrations:ui": "vitest --ui src/tests/migrations"
	},
	"dependencies": {
		"@base-ui/react": "^1.5.0",
		"@fortawesome/fontawesome-svg-core": "^7.2.0",
		"@fortawesome/free-regular-svg-icons": "^7.2.0",
		"@fortawesome/free-solid-svg-icons": "^7.2.0",
		"@fortawesome/react-fontawesome": "^3.3.1",
		"@legendapp/state": "3.0.0-beta.46",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-radio-group": "^1.3.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-toggle": "^1.1.10",
		"@radix-ui/react-toggle-group": "^1.1.11",
		"@rolldown/plugin-babel": "^0.2.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"file-saver": "^2.0.5",
		"happy-dom": "^20.10.2",
		"i18next": "^26.3.1",
		"i18next-browser-languagedetector": "^8.2.1",
		"i18next-http-backend": "^4.0.0",
		"lodash-es": "^4.18.1",
		"lucide-react": "^1.18.0",
		"next-themes": "^0.4.6",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-i18next": "^17.0.8",
		"react-scan": "^0.5.7",
		"sonner": "^2.0.7",
		"superjson": "^2.2.6",
		"tailwind-merge": "^3.6.0",
		"ts-pattern": "^5.9.0",
		"unocss-preset-animations": "^1.3.0",
		"valibot": "1.4.1",
		"vite-plugin-dynamic-import": "^1.6.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@iconify-json/logos": "^1.2.11",
		"@iconify-json/skill-icons": "^1.2.4",
		"@types/file-saver": "^2.0.7",
		"@types/lodash-es": "^4.17.12",
		"@types/node": "^25.9.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@unocss/preset-typography": "66.7.2",
		"@unocss/preset-wind4": "^66.7.2",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/coverage-v8": "^4.1.8",
		"@vitest/ui": "^4.1.8",
		"fake-indexeddb": "^6.2.5",
		"typescript": "6.0.3",
		"unocss": "66.7.2",
		"unocss-preset-shadcn": "^1.0.1",
		"vite": "^8.0.16",
		"vite-bundle-analyzer": "^1.3.8",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.8"
	},
	"config": {},
	"packageManager": "pnpm@10.32.1",
	"pnpm": {
		"overrides": {
			"workbox-build": "7.4.1",
			"workbox-window": "7.4.1",
			"braces@<3.0.3": ">=3.0.3",
			"preact@>=10.28.0 <10.28.2": ">=10.28.2",
			"rollup@>=4.0.0 <4.59.0": ">=4.59.0",
			"serialize-javascript@<=7.0.2": ">=7.0.3",
			"picomatch@<2.3.2": ">=2.3.2",
			"picomatch@>=4.0.0 <4.0.4": ">=4.0.4"
		},
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"esbuild"
		]
	}
}
