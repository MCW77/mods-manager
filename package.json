		"react-i18next": "^17.0.8",
		"react-scan": "^0.5.7",
		"sonner": "^2.0.7",
		"superjson": "^2.2.6",
		"tailwind-merge": "^3.6.0",
		"ts-pattern": "^5.9.0",
