		"@fortawesome/react-fontawesome": "^3.3.1",
		"@legendapp/state": "3.0.0-beta.46",
		"@rolldown/plugin-babel": "^0.2.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"file-saver": "^2.0.5",
		"happy-dom": "^20.10.6",
		"i18next": "^26.3.6",
		"i18next-browser-languagedetector": "^8.2.1",
		"i18next-http-backend": "^4.0.0",
